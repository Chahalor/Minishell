# Big Header

# ***************************************************** #
# *                 Configuation                      * #
# ***************************************************** #

MAKEFLAGS += --no-print-directory

# ***************************************************** #
# *                    Variables                      * #
# ***************************************************** #

# ...

# ***************************************************** #
# *                    Rules                          * #
# ***************************************************** #

.PHONY: all builtins args lexer exec signal main

all: builtins args lexer exec signal main

builtins: compile

args: compile
	

lexer: compile

exec: compile

signal: compile

main: compile

# ***************************************************** #
# *                  Compiling                        * #
# ***************************************************** #

compile:
	if [ ! -f "Makefile" ]; then \
		echo "Makefile not found!"; \
		exit 1; \
	fi
	$(MAKE) -C ../ -f Makefile all

# ***************************************************** #
# *                    Clean Rules                    * #
# ***************************************************** #

# ...

